# ---------------------------------------------------------
# .gitignore สำหรับโปรเจกต์ C# / .NET (Visual Studio)
# ---------------------------------------------------------

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio temporary / cache files
.vs/
*.user
*.userosscache
*.suo
*.userprefs
*.sln.docstates

# Build / restore artifacts
project.lock.json
project.fragment.lock.json
artifacts/
*.binlog

# MSBuild
*.tlog
*.log

# .NET build cache
*.cache

# Rider / JetBrains
.idea/
*.sln.iml

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Test results / coverage
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.info
TestResults/
.sonarqube/

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
.nuget/

# Entity Framework
# (เก็บ Migrations ไว้ใน repo, แต่ ignore ไฟล์ชั่วคราว)
*.dbmdl
*.dbproj.schemaview
*.jfm

# ASP.NET / publish
publish/
*.Publish.xml
*.pubxml
*.pubxml.user
PublishScripts/
*.azurePubxml

# User-specific & secrets
appsettings.*.local.json
appsettings.Development.json
secrets.json
*.pfx
*.p12
*.key
*.pem

# Application logs
*.log
logs/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
[Tt]humbs.db
Desktop.ini

# Backup & report files
*.bak
*.tmp
*.~*
*~

# Docker (เก็บ Dockerfile / compose ไว้ใน repo)
.dockerignore.local
